          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Response time is less than 250ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(250);\r",
              "});\r",
              "pm.test(\"City name is Cairo\", function () {\r",
              "const jsonData =pm.response.json();\r",
              "pm.expect(jsonData.city.name).to.eql(\"القاهرة\");\r",
              "});\r",
              "pm.test(\"Country name is EG\", function () {\r",
              "   const jsonData =pm.response.json();\r",
              "   pm.expect(jsonData.city.country).to.eql(\"EG\");\r",
              "});"
